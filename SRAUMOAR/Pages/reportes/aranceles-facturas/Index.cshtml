@page
@model SRAUMOAR.Pages.reportes.aranceles_facturas.IndexModel
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Reporte de Aranceles y Facturas";
}
<style>
    .col-arancel {
        width: 220px;
        min-width: 220px;
        max-width: 220px;
    }

    .detalle-arancel {
        white-space: pre-line;
        max-height: 3.2em;
        overflow: hidden;
        text-overflow: ellipsis;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        line-height: 1.6em;
    }
</style>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">Reporte de Aranceles y Facturas Válidas</h3>
        <div>
            <a asp-page="./Index"
               asp-page-handler="GenerarPDF"
               asp-route-ArancelId="@Model.ArancelId"
               asp-route-SelectedCicloId="@Model.SelectedCicloId"
               asp-route-FechaInicio="@Model.FechaInicio?.ToString("yyyy-MM-dd")"
               asp-route-FechaFin="@Model.FechaFin?.ToString("yyyy-MM-dd")"
               class="btn btn-danger me-2">
                PDF
            </a>
            <a asp-page="./Index"
               asp-page-handler="GenerarExcel"
               asp-route-ArancelId="@Model.ArancelId"
               asp-route-SelectedCicloId="@Model.SelectedCicloId"
               asp-route-FechaInicio="@Model.FechaInicio?.ToString("yyyy-MM-dd")"
               asp-route-FechaFin="@Model.FechaFin?.ToString("yyyy-MM-dd")"
               class="btn btn-success">
                Excel
            </a>
        </div>
    </div>

    <div class="mb-3">
        @if (Model.ArancelId.HasValue)
        {
            <a asp-page="./AlumnosPorArancel"
               asp-route-ArancelId="@Model.ArancelId"
               asp-route-CicloId="@Model.SelectedCicloId"
               asp-route-FechaInicio="@Model.FechaInicio?.ToString("yyyy-MM-dd")"
               asp-route-FechaFin="@Model.FechaFin?.ToString("yyyy-MM-dd")"
               class="btn btn-outline-primary">
                Ver alumnos que pagaron este arancel
            </a>
        }
        else
        {
            <button class="btn btn-outline-secondary" disabled>
                Seleccione un arancel para ver alumnos pagadores
            </button>
        }
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card mb-3">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-2">
                    <label class="form-label">Fecha Inicio</label>
                    <input type="date" class="form-control" name="FechaInicio"
                           value="@Model.FechaInicio?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Fecha Fin</label>
                    <input type="date" class="form-control" name="FechaFin"
                           value="@Model.FechaFin?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Ciclo</label>
                    <select name="SelectedCicloId" class="form-select">
                        @foreach (var item in (IEnumerable<SelectListItem>)ViewData["Ciclos"]!)
                        {
                            var selected = item.Value == Model.SelectedCicloId?.ToString();
                            <option value="@item.Value" selected="@selected">@item.Text</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Arancel</label>
                    <select name="ArancelId" class="form-select">
                        <option value="">Todos los aranceles</option>
                        @foreach (var item in (IEnumerable<SelectListItem>)ViewData["Aranceles"]!)
                        {
                            var selected = item.Value == Model.ArancelId?.ToString();
                            <option value="@item.Value" selected="@selected">@item.Text</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Filtrar</button>
                    <a asp-page="./Index" class="btn btn-outline-secondary">Limpiar</a>
                </div>
            </form>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-4">
            <div class="card text-bg-primary">
                <div class="card-body">
                    <div class="small">Total facturas válidas emitidas</div>
                    <div class="h5 mb-0">$@Model.TotalFacturasValidas.ToString("N2")</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-bg-success">
                <div class="card-body">
                    <div class="small">Total aranceles cobrados</div>
                    <div class="h5 mb-0">$@Model.TotalArancelesCobrados.ToString("N2")</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-bg-secondary">
                <div class="card-body">
                    <div class="small">Subtotal donaciones</div>
                    <div class="h5 mb-0">$@Model.SubtotalDonaciones.ToString("N2")</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Fecha</th>
                            <th>Tipo DTE</th>
                            <th>No. Control</th>
                            <th>Código Generación</th>
                            <th>Origen</th>
                                    <th class="col-arancel">Arancel</th>
                            <th>Total Factura</th>
                            <th>Monto Arancel</th>
                            <th>Donación</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Registros.Any())
                        {
                            @foreach (var item in Model.Registros)
                            {
                                <tr>
                                    <td>@item.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@item.TipoDTETexto</td>
                                    <td>@item.NumeroControl</td>
                                    <td><small>@item.CodigoGeneracion</small></td>
                                    <td>@item.Origen</td>
                                    <td class="detalle-arancel col-arancel" title="@item.ArancelNombre">@(item.ArancelNombre ?? "-")</td>
                                    <td class="text-end">$@item.TotalFactura.ToString("N2")</td>
                                    <td class="text-end">$@item.MontoArancel.ToString("N2")</td>
                                    <td>@(item.EsDonacion ? "Sí" : "No")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="9" class="text-center py-4">No hay registros para los filtros seleccionados.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
