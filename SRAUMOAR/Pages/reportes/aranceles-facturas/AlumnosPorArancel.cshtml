@page
@model SRAUMOAR.Pages.reportes.aranceles_facturas.AlumnosPorArancelModel
@{
    ViewData["Title"] = "Alumnos por Arancel";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0">Alumnos que pagaron arancel</h3>
            <small class="text-muted">
                Arancel: <strong>@Model.NombreArancel</strong> |
                Período: <strong>@Model.FechaInicio?.ToString("dd/MM/yyyy") - @Model.FechaFin?.ToString("dd/MM/yyyy")</strong>
            </small>
        </div>
        <div class="d-flex gap-2">
            <a asp-page="./AlumnosPorArancel"
               asp-page-handler="GenerarExcel"
               asp-route-ArancelId="@Model.ArancelId"
               asp-route-FechaInicio="@Model.FechaInicio?.ToString("yyyy-MM-dd")"
               asp-route-FechaFin="@Model.FechaFin?.ToString("yyyy-MM-dd")"
               class="btn btn-success">
                Exportar Excel
            </a>
            <a asp-page="./Index"
               asp-route-ArancelId="@Model.ArancelId"
               asp-route-FechaInicio="@Model.FechaInicio?.ToString("yyyy-MM-dd")"
               asp-route-FechaFin="@Model.FechaFin?.ToString("yyyy-MM-dd")"
               class="btn btn-outline-secondary">
                Regresar
            </a>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="row mb-3">
        <div class="col-md-4">
            <div class="card text-bg-primary">
                <div class="card-body">
                    <div class="small">Alumnos únicos</div>
                    <div class="h5 mb-0">@Model.TotalAlumnosUnicos</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-bg-info">
                <div class="card-body">
                    <div class="small">Total operaciones</div>
                    <div class="h5 mb-0">@Model.TotalOperaciones</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-bg-success">
                <div class="card-body">
                    <div class="small">Total pagado del arancel</div>
                    <div class="h5 mb-0">$@Model.TotalPagadoArancel.ToString("N2")</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Alumno</th>
                            <th>Carnet</th>
                            <th>Carrera</th>
                            <th>Fecha Factura</th>
                            <th>No. Control</th>
                            <th>Código Generación</th>
                            <th>Tipo DTE</th>
                            <th class="text-end">Monto Arancel</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Registros.Any())
                        {
                            @foreach (var item in Model.Registros)
                            {
                                <tr>
                                    <td>@item.AlumnoNombre</td>
                                    <td>@item.Carnet</td>
                                    <td>@item.Carrera</td>
                                    <td>@item.FechaFactura.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@item.NumeroControl</td>
                                    <td><small>@item.CodigoGeneracion</small></td>
                                    <td>@item.TipoDteTexto</td>
                                    <td class="text-end">$@item.MontoArancel.ToString("N2")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center py-4">
                                    No se encontraron pagos de este arancel en el período seleccionado.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
