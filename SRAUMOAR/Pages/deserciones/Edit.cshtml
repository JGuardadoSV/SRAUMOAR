@page "{id:int}"
@model SRAUMOAR.Pages.deserciones.EditModel
@{
    ViewData["Title"] = "Editar deserción";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Editar deserción o retiro</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Actualizar registro</h3>
            </div>
            <div class="card-body">
                <div class="alert alert-light border">
                    <strong>Alumno:</strong> @Model.AlumnoSeleccionado?.Apellidos, @Model.AlumnoSeleccionado?.Nombres
                    <br />
                    <strong>Carrera:</strong> @Model.AlumnoSeleccionado?.Carrera?.NombreCarrera
                </div>

                <form method="post">
                    <input asp-for="DesercionAlumno.DesercionAlumnoId" type="hidden" />
                    <input asp-for="DesercionAlumno.AlumnoId" type="hidden" />
                    <input asp-for="DesercionAlumno.FechaRegistro" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="DesercionAlumno.CicloId"></label>
                                <select asp-for="DesercionAlumno.CicloId" asp-items="@(ViewData["CicloId"] as SelectList)" class="form-control"></select>
                                <span asp-validation-for="DesercionAlumno.CicloId" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="DesercionAlumno.CausaDesercionId"></label>
                                <select asp-for="DesercionAlumno.CausaDesercionId" asp-items="@(ViewData["CausaDesercionId"] as SelectList)" class="form-control"></select>
                                <span asp-validation-for="DesercionAlumno.CausaDesercionId" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="form-group">
                                <label asp-for="DesercionAlumno.Observacion"></label>
                                <textarea asp-for="DesercionAlumno.Observacion" class="form-control" rows="4"></textarea>
                                <span asp-validation-for="DesercionAlumno.Observacion" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save"></i> Guardar cambios
                        </button>
                        <a asp-page="./Index" asp-route-SelectedCicloId="@Model.DesercionAlumno.CicloId" class="btn btn-secondary">Volver</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
