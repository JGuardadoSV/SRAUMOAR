@page
@model SRAUMOAR.Pages.generales.ciclos.EditarModel

@{
    ViewData["Title"] = "Editar";
    var estadoTexto = Model.Ciclo.Activo ? "Activo" : (Model.Ciclo.FechaInicio.Date > DateTime.Today ? "En preparación" : "Finalizado");
    var estadoClase = Model.Ciclo.Activo ? "bg-success" : (Model.Ciclo.FechaInicio.Date > DateTime.Today ? "bg-info text-dark" : "bg-secondary");
}

<style>
    .cycle-form-page {
        max-width: 920px;
        margin: 0 auto;
    }

    .page-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        margin-bottom: 1.25rem;
    }

    .page-title {
        margin: 0;
        color: #1f2937;
        font-weight: 700;
    }

    .page-subtitle {
        margin: .25rem 0 0;
        color: #6b7280;
    }

    .field-hint {
        color: #6b7280;
        font-size: .85rem;
        margin-top: .25rem;
    }

    @@media (max-width: 700px) {
        .page-toolbar {
            flex-direction: column;
        }
    }
</style>

<div class="cycle-form-page">
    <div class="page-toolbar">
        <div>
            <h4 class="page-title">Editar ciclo @Model.Ciclo.NCiclo-@Model.Ciclo.anio</h4>
            <p class="page-subtitle">Ajuste fechas, número de ciclo y correlativo sin cambiar el estado operativo.</p>
        </div>
        <a asp-page="./Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left-circle me-1"></i> Volver
        </a>
    </div>

    <div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0 text-primary"><i class="bi bi-pencil-square me-2"></i>Información del ciclo</h5>
                <span class="badge @estadoClase">@estadoTexto</span>
            </div>
            <div class="card-body">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Ciclo.Id" />
                    <input type="hidden" asp-for="Ciclo.Activo" />
                    
                    <div class="row g-3">
                        <div class="col-md-6 form-group">
                            <label asp-for="Ciclo.NCiclo" class="form-label fw-bold"></label>
                            <input asp-for="Ciclo.NCiclo" class="form-control" />
                            <div class="field-hint">Número académico del ciclo.</div>
                            <span asp-validation-for="Ciclo.NCiclo" class="text-danger"></span>
                        </div>
                        
                        <div class="col-md-6 form-group">
                            <label asp-for="Ciclo.anio" class="form-label fw-bold"></label>
                            <input asp-for="Ciclo.anio" class="form-control" />
                            <div class="field-hint">Año calendario del ciclo.</div>
                            <span asp-validation-for="Ciclo.anio" class="text-danger"></span>
                        </div>
                        
                        <div class="col-md-6 form-group">
                            <label asp-for="Ciclo.FechaInicio" class="form-label fw-bold"></label>
                            <input asp-for="Ciclo.FechaInicio" class="form-control" type="date" />
                            <span asp-validation-for="Ciclo.FechaInicio" class="text-danger"></span>
                        </div>
                        
                        <div class="col-md-6 form-group">
                            <label asp-for="Ciclo.FechaFin" class="form-label fw-bold"></label>
                            <input asp-for="Ciclo.FechaFin" class="form-control" type="date" />
                            <span asp-validation-for="Ciclo.FechaFin" class="text-danger"></span>
                        </div>
                        
                        <div class="col-12 form-group">
                            <label asp-for="Ciclo.CorrelativoCarnet" class="form-label fw-bold"></label>
                            <input asp-for="Ciclo.CorrelativoCarnet" class="form-control" />
                            <div class="field-hint">Siguiente correlativo para generación de carnet.</div>
                            <span asp-validation-for="Ciclo.CorrelativoCarnet" class="text-danger"></span>
                        </div>
                    </div>
                    
                    <div class="d-flex justify-content-end mt-4 gap-2">
                        <a asp-page="./Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left-circle me-1"></i> Volver al listado
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-1"></i> Actualizar datos
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
