@page
@model SRAUMOAR.Pages.generales.ciclos.EditModel

@{
    ViewData["Title"] = "Finalizar Ciclo";
    var diasTotales = (Model.Ciclo.FechaFin - Model.Ciclo.FechaInicio).Days;
}

<style>
    .finish-page {
        max-width: 900px;
        margin: 0 auto;
    }

    .page-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        margin-bottom: 1.25rem;
    }

    .page-title {
        margin: 0;
        color: #1f2937;
        font-weight: 700;
    }

    .page-subtitle {
        margin: .25rem 0 0;
        color: #6b7280;
    }

    .summary-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: .75rem;
        margin-bottom: 1rem;
    }

    .summary-item {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: .9rem;
    }

    .summary-label {
        color: #6b7280;
        font-size: .75rem;
        font-weight: 700;
        text-transform: uppercase;
    }

    .summary-value {
        color: #111827;
        font-weight: 800;
        margin-top: .25rem;
    }

    .switch-panel {
        border: 1px solid #fde68a;
        background: #fffbeb;
        border-radius: 8px;
        padding: 1rem;
    }

    @@media (max-width: 760px) {
        .summary-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .page-toolbar {
            flex-direction: column;
        }
    }
</style>

<div class="finish-page">
    <div class="page-toolbar">
        <div>
            <h4 class="page-title">Finalizar ciclo @Model.Ciclo.NCiclo-@Model.Ciclo.anio</h4>
            <p class="page-subtitle">Cierre el ciclo vigente cuando ya no deba usarse para procesos operativos.</p>
        </div>
        <a asp-page="./Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left-circle me-1"></i> Volver
        </a>
    </div>

    <div class="summary-grid">
        <div class="summary-item">
            <div class="summary-label">Ciclo</div>
            <div class="summary-value">@Model.Ciclo.NCiclo-@Model.Ciclo.anio</div>
        </div>
        <div class="summary-item">
            <div class="summary-label">Inicio</div>
            <div class="summary-value">@Model.Ciclo.FechaInicio.ToString("dd/MM/yyyy")</div>
        </div>
        <div class="summary-item">
            <div class="summary-label">Fin</div>
            <div class="summary-value">@Model.Ciclo.FechaFin.ToString("dd/MM/yyyy")</div>
        </div>
        <div class="summary-item">
            <div class="summary-label">Duración</div>
            <div class="summary-value">@diasTotales días</div>
        </div>
    </div>

    <div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm border-warning">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0"><i class="bi bi-exclamation-triangle-fill me-2"></i>Atención: Finalización de Ciclo</h5>
            </div>
            <div class="card-body">
                <form method="post" style="font-size:1.1rem;">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Ciclo.Id" />
                    <input type="hidden" asp-for="Ciclo.NCiclo" />
                    <input type="hidden" asp-for="Ciclo.anio" />
                    <input type="hidden" asp-for="Ciclo.FechaInicio" />
                    <input type="hidden" asp-for="Ciclo.FechaFin" />
                    <input type="hidden" asp-for="Ciclo.CorrelativoCarnet" />
                    
                    <div class="alert alert-info d-flex align-items-start mb-4" role="alert">
                        <i class="bi bi-info-circle-fill fs-4 me-3"></i>
                        <div>
                            Para finalizar este ciclo, apague el interruptor de estado y confirme. Después podrá activar un ciclo preparado desde el listado.
                        </div>
                    </div>
                    
                    <div class="form-check form-switch mb-4 text-center d-flex justify-content-center align-items-center gap-3 switch-panel">
                        <input class="form-check-input fs-3 m-0" type="checkbox" role="switch" id="switchActivo" asp-for="Ciclo.Activo" />
                        <label class="form-check-label fs-5 fw-bold ms-2" for="switchActivo">Ciclo activo</label>
                    </div>
                    
                    <div class="d-flex justify-content-end gap-2 mt-4 border-top pt-3">
                        <a asp-page="./Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle me-1"></i> Cancelar
                        </a>
                        <button type="submit" class="btn btn-warning fw-bold text-dark">
                            <i class="bi bi-save2-fill me-1"></i> Confirmar finalización
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
