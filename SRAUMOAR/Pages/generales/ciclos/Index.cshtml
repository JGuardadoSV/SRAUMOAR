@page
@model SRAUMOAR.Pages.generales.ciclos.IndexModel

@{
    ViewData["Title"] = "Administracion de ciclos";
    var totalCiclos = Model.Ciclo.Count;
    var cicloActivo = Model.Ciclo.FirstOrDefault(c => c.Activo);
    var ciclosPreparacion = Model.Ciclo.Count(c => !c.Activo && c.FechaInicio.Date > DateTime.Today);
    var ciclosFinalizados = Model.Ciclo.Count(c => !c.Activo && c.FechaInicio.Date <= DateTime.Today);
}

<style>
    .ciclos-page {
        max-width: 1220px;
        margin: 0 auto;
    }

    .page-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        margin-bottom: 1.25rem;
    }

    .page-title {
        margin: 0;
        color: #1f2937;
        font-weight: 700;
    }

    .page-subtitle {
        margin: .25rem 0 0;
        color: #6b7280;
    }

    .metric-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: .75rem;
        margin-bottom: 1rem;
    }

    .metric-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 1rem;
        min-height: 92px;
    }

    .metric-label {
        color: #6b7280;
        font-size: .78rem;
        font-weight: 700;
        letter-spacing: .03em;
        text-transform: uppercase;
    }

    .metric-value {
        color: #111827;
        font-size: 1.45rem;
        font-weight: 800;
        margin-top: .25rem;
    }

    .cycle-status {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        border-radius: 999px;
        padding: .35rem .65rem;
        font-size: .78rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .cycle-status-active {
        background: #dcfce7;
        color: #166534;
    }

    .cycle-status-draft {
        background: #e0f2fe;
        color: #075985;
    }

    .cycle-status-closed {
        background: #f3f4f6;
        color: #4b5563;
    }

    .actions-cell {
        min-width: 290px;
    }

    .action-group {
        display: flex;
        flex-wrap: wrap;
        gap: .35rem;
    }

    .empty-state {
        padding: 3rem 1rem;
        text-align: center;
        color: #6b7280;
    }

    @@media (max-width: 900px) {
        .metric-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .page-toolbar {
            flex-direction: column;
        }
    }

    @@media (max-width: 540px) {
        .metric-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="ciclos-page">
    <div class="page-toolbar">
        <div>
            <h4 class="page-title">Administración de ciclos lectivos</h4>
            <p class="page-subtitle">Controle el ciclo operativo y prepare aranceles para ciclos futuros.</p>
        </div>
        <a asp-page="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> Registrar ciclo
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success shadow-sm">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger shadow-sm">@TempData["Error"]</div>
    }

    <div class="metric-grid">
        <div class="metric-card">
            <div class="metric-label">Ciclo activo</div>
            <div class="metric-value">@(cicloActivo != null ? $"{cicloActivo.NCiclo}-{cicloActivo.anio}" : "Ninguno")</div>
        </div>
        <div class="metric-card">
            <div class="metric-label">En preparación</div>
            <div class="metric-value">@ciclosPreparacion</div>
        </div>
        <div class="metric-card">
            <div class="metric-label">Finalizados</div>
            <div class="metric-value">@ciclosFinalizados</div>
        </div>
        <div class="metric-card">
            <div class="metric-label">Total registrados</div>
            <div class="metric-value">@totalCiclos</div>
        </div>
    </div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0 text-primary"><i class="bi bi-calendar3 me-2"></i>Ciclos lectivos</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Estado</th>
                        <th>Ciclo</th>
                        <th>Año</th>
                        <th>Inicio</th>
                        <th>Fin</th>
                        <th>Días</th>
                        <th>Correlativo carnet</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Ciclo.Any())
                    {
                        @foreach (var item in Model.Ciclo)
                        {
                            var esPreparacion = !item.Activo && item.FechaInicio.Date > DateTime.Today;
                            var diasTotales = (item.FechaFin - item.FechaInicio).Days;

                            <tr>
                                <td>
                                    @if (item.Activo)
                                    {
                                        <span class="cycle-status cycle-status-active"><i class="bi bi-check-circle-fill"></i>Activo</span>
                                    }
                                    else if (esPreparacion)
                                    {
                                        <span class="cycle-status cycle-status-draft"><i class="bi bi-hourglass-split"></i>En preparación</span>
                                    }
                                    else
                                    {
                                        <span class="cycle-status cycle-status-closed"><i class="bi bi-archive-fill"></i>Finalizado</span>
                                    }
                                </td>
                                <td><strong>@item.NCiclo</strong></td>
                                <td>@item.anio</td>
                                <td>@item.FechaInicio.ToString("dd/MM/yyyy")</td>
                                <td>@item.FechaFin.ToString("dd/MM/yyyy")</td>
                                <td>@diasTotales días</td>
                                <td>@item.CorrelativoCarnet</td>
                                <td class="actions-cell">
                                    <div class="action-group">
                                    @if (item.Activo)
                                    {
                                        <a asp-page="./Editar" asp-route-id="@item.Id" class="btn btn-success btn-sm me-1 mb-1" title="Modificar">
                                            <i class="bi bi-pencil-fill"></i> Modificar
                                        </a>
                                        <a asp-page="/aranceles/Index" asp-route-cicloId="@item.Id" class="btn btn-info btn-sm mb-1 text-white" title="Aranceles">
                                            <i class="bi bi-coin"></i> Aranceles
                                        </a>
                                        <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm me-1 mb-1" title="Finalizar">
                                            <i class="bi bi-stop-circle-fill"></i> Finalizar
                                        </a>
                                    }
                                    else if (esPreparacion)
                                    {
                                            <a asp-page="./Editar" asp-route-id="@item.Id" class="btn btn-success btn-sm me-1 mb-1" title="Modificar">
                                                <i class="bi bi-pencil-fill"></i> Modificar
                                            </a>
                                            <a asp-page="/aranceles/Index" asp-route-cicloId="@item.Id" class="btn btn-info btn-sm me-1 mb-1 text-white" title="Aranceles">
                                                <i class="bi bi-coin"></i> Aranceles
                                            </a>
                                            <form method="post" asp-page-handler="Activar" asp-route-id="@item.Id" class="d-inline">
                                                <button type="submit" class="btn btn-warning btn-sm mb-1" title="Activar">
                                                    <i class="bi bi-play-circle-fill"></i> Activar
                                                </button>
                                            </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Sin acciones disponibles</span>
                                    }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8">
                                <div class="empty-state">
                                    <i class="bi bi-calendar-x fs-1 d-block mb-2"></i>
                                    No hay ciclos registrados.
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
</div>
