@page
@model SRAUMOAR.Pages.generales.pensum.EditModel

@{
    ViewData["Title"] = "Edición de pensum";
}

<div class="row mb-3">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <div>
            <h1 class="h3 mb-0">Edición de pensum</h1>
            <small class="text-muted">Actualiza los datos básicos del pensum seleccionado.</small>
        </div>
        <a asp-page="./Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left-circle"></i> Volver al listado
        </a>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8 col-xl-6">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">
                    <i class="bi bi-journal-text me-1"></i>
                    Datos del pensum
                </h5>
            </div>
            <div class="card-body">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Pensum.PensumId" />

                    <div class="mb-3">
                        <label asp-for="Pensum.NombrePensum" class="form-label"></label>
                        <input asp-for="Pensum.NombrePensum" class="form-control" />
                        <span asp-validation-for="Pensum.NombrePensum" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Pensum.CodigoPensum" class="form-label"></label>
                            <input asp-for="Pensum.CodigoPensum" class="form-control" />
                            <span asp-validation-for="Pensum.CodigoPensum" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Pensum.Anio" class="form-label"></label>
                            <input asp-for="Pensum.Anio" class="form-control" />
                            <span asp-validation-for="Pensum.Anio" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row align-items-center mb-3">
                        <div class="col-md-6">
                            <label asp-for="Pensum.CarreraId" class="form-label"></label>
                            <select asp-for="Pensum.CarreraId" class="form-select" asp-items="ViewBag.CarreraId"></select>
                            <span asp-validation-for="Pensum.CarreraId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mt-3 mt-md-0">
                            <div class="form-check mt-4">
                                <input class="form-check-input" asp-for="Pensum.Activo" id="PensumActivoCheck" />
                                <label class="form-check-label" for="PensumActivoCheck">
                                    @Html.DisplayNameFor(model => model.Pensum.Activo)
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-page="./Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle"></i> Cancelar
                        </a>
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-save"></i> Guardar cambios
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
