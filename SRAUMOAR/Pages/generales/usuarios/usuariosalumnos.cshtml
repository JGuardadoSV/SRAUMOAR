@page
@model SRAUMOAR.Pages.generales.usuarios.usuariosalumnosModel

@{
    ViewData["Title"] = "Gestión de Usuarios";
}

@functions {
    string GetRoleBadgeClass(string role)
    {
        if (string.IsNullOrEmpty(role)) return "bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25";
        role = role.ToLower();
        if (role.Contains("admin")) return "bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25";
        if (role.Contains("docente")) return "bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25";
        if (role.Contains("alumno") || role.Contains("estudiante")) return "bg-success bg-opacity-10 text-success border border-success border-opacity-25";
        if (role.Contains("colecturia")) return "bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25";
        return "bg-info bg-opacity-10 text-info border border-info border-opacity-25";
    }
}

<div class="row mb-4 align-items-center">
    <div class="col-md-8">
        <h2 class="mt-2 text-success"><i class="bi bi-people-fill text-success me-2"></i> Gestión de Usuarios</h2>
        <p class="text-muted mb-0">Controle el acceso, asigne roles y active/desactive cuentas de usuario en la plataforma.</p>
    </div>
    <div class="col-md-4 mt-3 mt-md-0">
        <div class="input-group shadow-sm">
            <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
            <input type="text" id="searchUser" class="form-control border-start-0" placeholder="Buscar usuario o correo..." aria-label="Buscar usuario" />
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="usuariosTable">
                <thead class="table-light">
                    <tr>
                        <th class="rounded-start">Usuario</th>
                        <th>Correo Electrónico</th>
                        <th>Rol / Nivel de Acceso</th>
                        <th>Estado</th>
                        <th class="text-center rounded-end" style="width: 15%;">Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Usuario)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="bg-success bg-opacity-10 p-2 rounded-circle me-3">
                                        <i class="bi bi-person text-success fs-5"></i>
                                    </div>
                                    <span class="fw-semibold text-dark">@Html.DisplayFor(modelItem => item.NombreUsuario)</span>
                                </div>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.Email))
                                {
                                    <span class="text-muted"><i class="bi bi-envelope me-1.5 text-secondary"></i>@item.Email</span>
                                }
                                else
                                {
                                    <span class="text-muted italic small">No registrado</span>
                                }
                            </td>
                            <td>
                                <span class="badge px-2.5 py-1.5 @GetRoleBadgeClass(item.NivelAcceso?.Nombre)">
                                    @Html.DisplayFor(modelItem => item.NivelAcceso.Nombre)
                                </span>
                            </td>
                            <td>
                                @if (item.Activo == true)
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-2.5 py-1.5">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-2.5 py-1.5">Inactivo</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (item.Activo == true)
                                {
                                    <a href="/autenticacion/desactivarusuario/@item.IdUsuario" onclick="return confirm('¿Está seguro de que desea desactivar este usuario?')" class="btn btn-sm btn-outline-danger shadow-sm rounded-pill px-3">
                                        <i class="bi bi-person-x me-1"></i> Desactivar
                                    </a>
                                }
                                else
                                {
                                    <a href="/autenticacion/desactivarusuario/@item.IdUsuario" onclick="return confirm('¿Está seguro de que desea activar este usuario?')" class="btn btn-sm btn-outline-success shadow-sm rounded-pill px-3">
                                        <i class="bi bi-person-check me-1"></i> Activar
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        jQuery(document).ready(function () {
            // Buscador dinámico de usuarios y correos en tiempo real
            jQuery('#searchUser').on('keyup input', function () {
                const value = jQuery(this).val().toLowerCase().trim();
                jQuery('#usuariosTable tbody tr').each(function () {
                    const text = jQuery(this).text().toLowerCase();
                    if (text.indexOf(value) > -1) {
                        jQuery(this).show();
                    } else {
                        jQuery(this).hide();
                    }
                });
            });
        });
    </script>
}

